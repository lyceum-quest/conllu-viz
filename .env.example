# conllu-viz environment configuration
# Copy this file to .env and fill in your values.

# Deploy target (SSH user@host)
TARGET_HOST=

# Remote directory where dist/ will be rsynced
REMOTE_DIR=

# Database path for import script
CONLLU_DB_PATH=

# Edition map for import script (optional, defaults to ./conllu-edition-map.json)
# CONLLU_MAP_PATH=./conllu-edition-map.json
